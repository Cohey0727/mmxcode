#!/usr/bin/env bash
# mmxcode: launch Claude Code with MiniMax as the backend.
#
# Why "mmxcode" and not "minimax" or "mmx"? Both of those command names are
# already taken on a typical machine and would collide:
#   - `minimax` -> ~/.mavis/bin/minimax (the official MiniMax Code desktop app)
#   - `mmx`     -> ~/.bun/bin/mmx (an unrelated bun-installed tool)
# `mmxcode` is unambiguous and avoids shadowing either of them.
#
# Generated by `make install`. The ENV_FILE path below is baked in
# from the directory you ran `make install` from. Re-run `make install`
# if you move the project.

set -euo pipefail

ENV_FILE="@@ENV_FILE@@"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "mmxcode: env file not found at $ENV_FILE" >&2
  echo "  re-run 'make install' from the project root." >&2
  exit 1
fi

# Load KEY=VALUE pairs from the env file and auto-export them.
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

if [[ -z "${MINIMAX_API_KEY:-}" ]]; then
  echo "mmxcode: MINIMAX_API_KEY is empty in $ENV_FILE" >&2
  echo "  edit the file and set MINIMAX_API_KEY=sk-cp-..." >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"
export ANTHROPIC_AUTH_TOKEN="$MINIMAX_API_KEY"
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-MiniMax-M3}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-MiniMax-M3}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-MiniMax-M3}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-MiniMax-M3}"
export API_TIMEOUT_MS="${API_TIMEOUT_MS:-3000000}"
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-512000}"

# A stale ANTHROPIC_API_KEY in the environment would shadow AUTH_TOKEN.
unset ANTHROPIC_API_KEY

exec claude "$@"
